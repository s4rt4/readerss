{
  "name": "ReadeRSS",
  "short_name": "ReadeRSS",
  "description": "Self-hosted RSS reader",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f7f7f4",
  "theme_color": "#fbb03b",
  "icons": [
    {
      "src": "/static/img/readerss_favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/static/img/readerss.ico",
      "sizes": "16x16 32x32 48x48",
      "type": "image/x-icon"
    }
  ]
}
